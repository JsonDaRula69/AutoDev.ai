{
  "name": "autodev-ai",
  "version": "0.1.1",
  "description": "AutoDev — Autonomous Engineering Team. DevTeam in a Box. Runs on pi.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/JsonDaRula69/AutoDev.ai.git"
  },
  "packageManager": "bun@1.3.14",
  "bin": {
    "autodev": "./bin/autodev.js"
  },
  "files": [
    "extensions/autodev/",
    "scripts/cli.ts",
    "scripts/onboard.ts",
    "bin/autodev.js",
    "install.sh",
    "config/",
    ".pi/settings.json",
    ".pi/magic-context.jsonc",
    ".pi/agents/",
    ".pi/skills/",
    ".autodev/config/",
    "AGENTS.md",
    "README.md",
    "ARCHITECTURE.md",
    "STRUCTURE.md",
    "CONTEXT.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "import-check": "bun run test/import-check.ts"
  },
  "dependencies": {
    "@cortexkit/pi-magic-context": "^0.26.0",
    "@earendil-works/pi-coding-agent": "^0.79.9",
    "js-yaml": "^4.1.0",
    "minimatch": "^10.2.5"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/js-yaml": "^4.0.9",
    "typescript": "^6.0.3"
  },
  "pi": {
    "extensions": [
      "./extensions/autodev"
    ]
  }
}