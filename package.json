{
  "name": "autodev",
  "version": "0.1.0",
  "description": "AutoDev — Autonomous Engineering Team. DevTeam in a Box. Runs on pi.",
  "license": "MIT",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "bin": {
    "autodev": "./scripts/cli.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "import-check": "bun run test/import-check.ts"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "latest",
    "@cortexkit/pi-magic-context": "latest"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "latest"
  },
  "pi": {
    "extensions": [
      "./extensions/autodev"
    ]
  }
}